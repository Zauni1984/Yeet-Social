# VPS .env  copy to /root/yeet-social/.env on the VPS, fill, chmod 600.
# Loaded by docker-compose.yml AND vps/start_backend.sh.
# NEVER commit a filled-in version of this file.

# Postgres password for the `yeet` user
POSTGRES_PASSWORD=CHANGE_ME

# JWT signing secret  generate with:  openssl rand -hex 64
# Rotating this invalidates all current user sessions.
JWT_SECRET=CHANGE_ME

# Admin endpoint secret (used by /api/v1/admin/*)
ADMIN_SECRET=CHANGE_ME

# Optional log level
RUST_LOG=backend=info,tower_http=warn
