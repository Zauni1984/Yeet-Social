# VPS .env  copy to /root/yeet-social/.env on the VPS, fill, chmod 600.
# Loaded by docker-compose.yml AND vps/start_backend.sh.
# NEVER commit a filled-in version of this file.

# Postgres password for the `yeet` user
POSTGRES_PASSWORD=CHANGE_ME

# JWT signing secret  generate with:  openssl rand -hex 64
# Rotating this invalidates all current user sessions.
JWT_SECRET=CHANGE_ME

# Admin endpoint secret (used by /api/v1/admin/*)
ADMIN_SECRET=CHANGE_ME

# Optional log level
RUST_LOG=backend=info,tower_http=warn

# SMTP (GDPR double-opt-in verification email). Hostinger example:
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465
#   SMTP_USER=noreply@justyeet.it
#   SMTP_PASS=your_password_here
#   SMTP_FROM=noreply@justyeet.it
# If SMTP_* are unset, verification tokens are created but no email is sent.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Public URL used in verification links (no trailing slash)
PUBLIC_BASE_URL=https://justyeet.it
