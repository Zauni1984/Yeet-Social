# BNB Smart Chain deployment
# 
# Testnet faucet: https://testnet.bnbchain.org/faucet-smart
# BSCScan API:    https://bscscan.com/myapikey
#
# Chain IDs:
#   Testnet: 97   RPC: https://bsc-testnet-dataseed.bnbchain.org
#   Mainnet: 56   RPC: https://bsc-dataseed.bnbchain.org

PRIVATE_KEY=0x_your_deployer_private_key
BSCSCAN_API_KEY=your_bscscan_api_key

# Optional: dedicated reward pool wallet (defaults to deployer)
REWARD_POOL=0x_reward_pool_address

# Filled after deployment:
YEET_TOKEN_ADDRESS=
YEET_TIPPING_ADDRESS=
YEET_NFT_ADDRESS=
YEET_CHAIN_ID=97